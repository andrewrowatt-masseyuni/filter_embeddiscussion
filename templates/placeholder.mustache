{{!
    @template filter_embeddiscussion/placeholder

    Skeleton container rendered in place of the {embeddiscussion:...} token.
    The JS module locates these elements via data-region and replaces the
    skeleton with the live discussion shell.

    The skeleton mirrors the real layout (header + sort, composer row, posts
    with avatar/meta/content/actions, plus an indented reply) so the page
    doesn't reflow when the live content hydrates.

    Classes required for JS:
    * filter-embeddiscussion

    Data attributes required for JS:
    * data-region="filter-embeddiscussion"
    * data-thread-name
    * data-anonymous
    * data-locked
    * data-contextid

    Context variables required for this template:
    * uid (string)
    * threadname (string)
    * anonymous (string, '1' or '0')
    * locked (string, '1' or '0')
    * contextid (int)

    Example context (json):
    {
        "uid": "embeddisc_1234",
        "threadname": "Demo",
        "anonymous": "0",
        "locked": "0",
        "contextid": 42
    }
}}
<div class="filter-embeddiscussion" data-region="filter-embeddiscussion" id="{{uid}}" data-thread-name="{{threadname}}" data-anonymous="{{anonymous}}" data-locked="{{locked}}" data-contextid="{{contextid}}">
  <div class="embeddisc embeddisc-skeleton" aria-hidden="true">
    <div class="embeddisc-header">
      <div class="embeddisc-header-row">
        <div class="embeddisc-skeleton-block embeddisc-skeleton-title"></div>
        <div class="embeddisc-sort">
          <div class="embeddisc-skeleton-block embeddisc-skeleton-sort"></div>
          <div class="embeddisc-skeleton-block embeddisc-skeleton-sort"></div>
        </div>
      </div>
      <hr class="embeddisc-divider">
    </div>

    <div class="embeddisc-composer">
      <div class="embeddisc-composer-row">
        <div class="embeddisc-skeleton-block embeddisc-skeleton-avatar"></div>
        <div class="embeddisc-composer-main">
          <div class="embeddisc-skeleton-block embeddisc-skeleton-trigger"></div>
        </div>
      </div>
    </div>

    <div class="embeddisc-skeleton-post">
      <div class="embeddisc-skeleton-block embeddisc-skeleton-avatar"></div>
      <div class="embeddisc-skeleton-post-body">
        <div class="embeddisc-skeleton-meta">
          <div class="embeddisc-skeleton-block embeddisc-skeleton-name"></div>
          <div class="embeddisc-skeleton-block embeddisc-skeleton-role"></div>
        </div>
        <div class="embeddisc-skeleton-block embeddisc-skeleton-time"></div>
        <div class="embeddisc-skeleton-block embeddisc-skeleton-content"></div>
        <div class="embeddisc-skeleton-actions">
          <div class="embeddisc-skeleton-block embeddisc-skeleton-action"></div>
          <div class="embeddisc-skeleton-block embeddisc-skeleton-action"></div>
          <div class="embeddisc-skeleton-block embeddisc-skeleton-action"></div>
        </div>

        <div class="embeddisc-skeleton-post">
          <div class="embeddisc-skeleton-block embeddisc-skeleton-avatar"></div>
          <div class="embeddisc-skeleton-post-body">
            <div class="embeddisc-skeleton-meta">
              <div class="embeddisc-skeleton-block embeddisc-skeleton-name"></div>
            </div>
            <div class="embeddisc-skeleton-block embeddisc-skeleton-time"></div>
            <div class="embeddisc-skeleton-block embeddisc-skeleton-content embeddisc-skeleton-content-short"></div>
            <div class="embeddisc-skeleton-actions">
              <div class="embeddisc-skeleton-block embeddisc-skeleton-action"></div>
              <div class="embeddisc-skeleton-block embeddisc-skeleton-action"></div>
              <div class="embeddisc-skeleton-block embeddisc-skeleton-action"></div>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="sr-only">{{#str}}threadnotinitialised, filter_embeddiscussion{{/str}}</div>
  </div>
</div>
